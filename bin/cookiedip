#!/usr/bin/env node

const puppeteer = require('puppeteer');
const { printUsage, normalizeUrl, supportedTypes } = require('./utils');
const collectBrowserStorage = require('./browserStorage');
const setupNetworkMonitor = require('./networkMonitor');

const DEFAULT_TIMEOUT_MS = 45000;
const DEFAULT_POLL_DELAY_MS = 1000;
const DEFAULT_POLL_TIMES = 5;

// Parse the command-line arguments into URL, type, polling options, and help flags.
// Supports positional URL and type, plus --poll-delay, --poll-times, and --help/-h options.
function parseCommandLineArgs(args) {
  const positionals = [];
  const parsed = { help: false };

  const readOptionValue = (optionName, index) => {
    const next = args[index + 1];
    if (!next || next.startsWith('-')) {
      throw new Error(`Missing value for ${optionName}`);
    }
    return next;
  };

  for (let i = 0; i < args.length; i += 1) {
    const arg = args[i];

    if (arg === '-h' || arg === '--help') {
      parsed.help = true;
    } else if (arg === '--poll-delay') {
      parsed.pollDelay = readOptionValue(arg, i);
      i += 1;
    } else if (arg.startsWith('--poll-delay=')) {
      parsed.pollDelay = arg.slice('--poll-delay='.length);
    } else if (arg === '--poll-times') {
      parsed.pollTimes = readOptionValue(arg, i);
      i += 1;
    } else if (arg.startsWith('--poll-times=')) {
      parsed.pollTimes = arg.slice('--poll-times='.length);
    } else if (arg.startsWith('-')) {
      throw new Error(`Unsupported option: ${arg}`);
    } else {
      positionals.push(arg);
    }
  }

  if (positionals.length > 2) {
    throw new Error(`Unexpected argument(s): ${positionals.slice(2).join(', ')}`);
  }

  parsed.url = positionals[0];
  parsed.typeArg = positionals[1];
  return parsed;
}

// Validate a single requested output type.
function parseTypes(typeArg) {
  const type = typeArg.trim();

  if (type.includes(',')) {
    throw new Error('Multiple types are not supported. Provide one type only.');
  }

  if (!supportedTypes.includes(type)) {
    throw new Error(`Unsupported type: ${type}`);
  }

  return [type];
}

function parsePositiveInteger(value, optionName) {
  const parsed = Number(value);
  if (!Number.isInteger(parsed) || parsed <= 0) {
    throw new Error(`Invalid ${optionName}: ${value}`);
  }
  return parsed;
}

function parsePollingOptions(parsedArgs) {
  return {
    pollDelayMs:
      parsedArgs.pollDelay === undefined
        ? DEFAULT_POLL_DELAY_MS
        : parsePositiveInteger(parsedArgs.pollDelay, '--poll-delay'),
    pollTimes:
      parsedArgs.pollTimes === undefined
        ? DEFAULT_POLL_TIMES
        : parsePositiveInteger(parsedArgs.pollTimes, '--poll-times'),
  };
}

// Launch Puppeteer, navigate to the target URL, and collect browser storage data.
async function run(url, types, timeoutMs, pollingOptions) {
  const browser = await puppeteer.launch({
    headless: true,
    args: ['--no-sandbox', '--disable-setuid-sandbox'],
  });

  const page = await browser.newPage();
  await page.setDefaultNavigationTimeout(timeoutMs);

  const networkData = setupNetworkMonitor(page);

  try {
    await page.goto(url, {
      waitUntil: ['load', 'networkidle2'],
      timeout: timeoutMs,
    });

    const results = {};

    if (types.includes('browserStorage')) {
      results.browserStorage = await collectBrowserStorage(page, networkData, pollingOptions);
    }

    return results;
  } finally {
    await browser.close();
  }
}

(async function main() {
  const args = process.argv.slice(2);

  let parsed;
  try {
    parsed = parseCommandLineArgs(args);
  } catch (error) {
    console.error('Error:', error.message);
    printUsage();
    process.exit(1);
  }

  if (parsed.help || args.length === 0) {
    printUsage();
    process.exit(0);
  }

  if (!parsed.url) {
    console.error('Error: URL is required.');
    printUsage();
    process.exit(1);
  }

  let types;
  let pollingOptions;
  try {
    types = parseTypes(parsed.typeArg || 'browserStorage');
    pollingOptions = parsePollingOptions(parsed);
  } catch (error) {
    console.error('Error:', error.message);
    printUsage();
    process.exit(1);
  }

  const targetUrl = normalizeUrl(parsed.url);

  try {
    const result = await run(targetUrl, types, DEFAULT_TIMEOUT_MS, pollingOptions);
    console.log(JSON.stringify(result, null, 2));
  } catch (error) {
    console.error('Error:', error.message || error);
    process.exit(1);
  }
})();
